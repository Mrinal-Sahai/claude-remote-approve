{
  "name": "claude-remote-approve",
  "displayName": "Claude Remote Approve (Telegram)",
  "description": "Approve Claude Code permission prompts from your phone over Telegram — Allow/Deny/Always buttons. Hands-free in both the VS Code panel and the CLI, on macOS, Windows & Linux.",
  "version": "0.2.2",
  "publisher": "MrinalSahai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mrinal-Sahai/claude-remote-approve.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "telegram",
    "approval",
    "remote",
    "cli",
    "hands-free",
    "permissions",
    "agentic",
    "windows",
    "linux"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeTgApprove.setup",
        "title": "Telegram Approve: Setup / Connect bot"
      },
      {
        "command": "claudeTgApprove.toggle",
        "title": "Telegram Approve: Enable / Disable"
      },
      {
        "command": "claudeTgApprove.manageAllowlist",
        "title": "Telegram Approve: Manage 'Always' allowlist"
      },
      {
        "command": "claudeTgApprove.openLog",
        "title": "Telegram Approve: Open log"
      },
      {
        "command": "claudeTgApprove.reconnect",
        "title": "Telegram Approve: Reconnect / change bot"
      },
      {
        "command": "claudeTgApprove.uninstall",
        "title": "Telegram Approve: Uninstall hooks"
      }
    ]
  },
  "scripts": {
    "copy-scripts": "node ./build/copy-scripts.js",
    "compile": "npm run copy-scripts && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "lint": "tsc --noEmit -p ./",
    "test:unit": "npm run compile && node --test test/unit/*.test.js",
    "test:integration": "npm run compile && vscode-test",
    "test": "npm run test:unit"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^11.7.6",
    "typescript": "^5.4.0"
  }
}
